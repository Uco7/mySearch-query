

       <%- include('../includeFolder/_headers.ejs') %>

<section class="hero">
  <h1>GPA & CGPA Calculator</h1>
  <p>Calculate your semester GPA, cumulative CGPA, and expected degree classification — instantly, right in your browser.</p>
</section>

<div class="container">

  <!-- Grading scale selector -->
  <div class="section-txt">
    <h2>1. Choose Your Grading Scale</h2>
    <p>Most Nigerian universities use the 5-point scale. Some polytechnics and a few private
      universities use the 4-point scale. <strong>Confirm which one your school uses</strong> in
      your student handbook if you're not sure — this changes the grade points below.</p>
    <div class="gpa-scale-toggle">
      <label><input type="radio" name="gpaScale" value="5" id="scale5" checked> 5-Point Scale (A=5, most common)</label>
      <label><input type="radio" name="gpaScale" value="4" id="scale4"> 4-Point Scale (A=4)</label>
    </div>
  </div>

  <!-- Course table -->
  <div class="section-txt">
    <h2>2. Enter This Semester's Courses</h2>
    <div class="gpa-table-wrapper">
      <table class="gpa-table" id="gpaTable">
        <thead>
          <tr>
            <th>Course Title (optional)</th>
            <th>Credit Unit</th>
            <th>Grade</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="gpaTableBody">
          <!-- rows injected by JS -->
        </tbody>
      </table>
    </div>
    <button type="button" class="cta-button" id="addRowBtn">+ Add Course</button>
    <button type="button" class="cta-button gpa-btn-secondary" id="resetBtn">Reset All</button>
  </div>

  <!-- Semester GPA result -->
  <div class="section-txt">
    <h2>3. Semester GPA</h2>
    <div class="info-section">
      <div class="info-card">
        <h3>Total Units</h3>
        <p id="totalUnits">0</p>
      </div>
      <div class="info-card">
        <h3>Total Grade Points</h3>
        <p id="totalPoints">0.00</p>
      </div>
      <div class="info-card">
        <h3>Semester GPA</h3>
        <p id="semesterGPA">0.00</p>
      </div>
    </div>
    <button type="button" class="cta-button" id="calcGpaBtn">Calculate Semester GPA</button>
  </div>

  <!-- Cumulative CGPA -->
  <div class="section-txt">
    <h2>4. Cumulative CGPA (Optional)</h2>
    <p>Already have a CGPA from previous semesters? Add it below to calculate your new cumulative CGPA after this semester.</p>
    <div class="gpa-cumulative-inputs">
      <label>Previous CGPA:
        <input type="number" id="prevCGPA" step="0.01" min="0" max="5" placeholder="e.g. 3.45">
      </label>
      <label>Previous Total Units:
        <input type="number" id="prevUnits" min="0" placeholder="e.g. 90">
      </label>
    </div>
    <button type="button" class="cta-button" id="calcCgpaBtn">Calculate Cumulative CGPA</button>
    <div class="info-section">
      <div class="info-card">
        <h3>New Cumulative CGPA</h3>
        <p id="cumulativeCGPA">—</p>
      </div>
    </div>
  </div>

  <!-- Degree classification -->
  <div class="section-txt">
    <h2>5. Expected Degree Classification</h2>
    <p>Based on the CGPA calculated above (uses cumulative CGPA if you entered previous results,
      otherwise uses this semester's GPA). <strong>Classification bands vary slightly by
      institution</strong> — this reflects the most common Nigerian university bands. Always
      confirm the exact bands in your school's academic regulations / student handbook.</p>
    <div class="info-section">
      <div class="info-card" id="classificationCard">
        <h3>Classification</h3>
        <p id="classificationResult">Enter your courses above to see your result</p>
      </div>
    </div>
    <table class="gpa-table gpa-reference-table">
      <thead>
        <tr><th>CGPA Range (5-Point)</th><th>Classification</th></tr>
      </thead>
      <tbody>
        <tr><td>4.50 – 5.00</td><td>First Class Honours</td></tr>
        <tr><td>3.50 – 4.49</td><td>Second Class Honours (Upper Division)</td></tr>
        <tr><td>2.40 – 3.49</td><td>Second Class Honours (Lower Division)</td></tr>
        <tr><td>1.50 – 2.39</td><td>Third Class Honours</td></tr>
        <tr><td>1.00 – 1.49</td><td>Pass</td></tr>
      </tbody>
    </table>
  </div>

</div>

<style>
  .gpa-scale-toggle{display:flex;flex-wrap:wrap;gap:1.5rem;margin-top:0.8rem;}
  .gpa-scale-toggle label{cursor:pointer;font-weight:500;}
  .gpa-table-wrapper{overflow-x:auto;margin:1rem 0;}
  .gpa-table{width:100%;border-collapse:collapse;background:#fff;}
  .gpa-table th, .gpa-table td{border:1px solid #ddd;padding:10px;text-align:left;font-size:0.95rem;}
  .gpa-table th{background:#4CAF50;color:#fff;}
  .gpa-table input, .gpa-table select{width:100%;padding:6px;border:1px solid #ccc;border-radius:4px;font-size:0.95rem;}
  .gpa-remove-btn{background:#f44336;color:#fff;border:none;border-radius:4px;padding:6px 10px;cursor:pointer;}
  .gpa-remove-btn:hover{background:#d32f2f;}
  .gpa-btn-secondary{background:#777;}
  .gpa-btn-secondary:hover{background:#555;}
  .gpa-cumulative-inputs{display:flex;flex-wrap:wrap;gap:1.5rem;margin:1rem 0;}
  .gpa-cumulative-inputs label{display:flex;flex-direction:column;font-weight:500;gap:4px;}
  .gpa-cumulative-inputs input{padding:8px;border:1px solid #ccc;border-radius:5px;width:180px;}
  .gpa-reference-table{margin-top:1rem;max-width:600px;}
  #classificationResult{font-weight:700;font-size:1.1rem;}

  @media (max-width: 480px) {
    .gpa-cumulative-inputs input{width:100%;}
    .gpa-table th, .gpa-table td{padding:6px;font-size:0.85rem;}
  }
</style>

<script>
(function () {
  const gradePoints5 = { A: 5, B: 4, C: 3, D: 2, E: 1, F: 0 };
  const gradePoints4 = { A: 4, B: 3, C: 2, D: 1, F: 0 };

  const tableBody = document.getElementById("gpaTableBody");
  const addRowBtn = document.getElementById("addRowBtn");
  const resetBtn = document.getElementById("resetBtn");
  const calcGpaBtn = document.getElementById("calcGpaBtn");
  const calcCgpaBtn = document.getElementById("calcCgpaBtn");

  function currentScale() {
    return document.getElementById("scale5").checked ? gradePoints5 : gradePoints4;
  }

  function buildGradeOptions() {
    const scale = currentScale();
    return Object.keys(scale).map(g => `<option value="${g}">${g}</option>`).join("");
  }

  function addRow() {
    const row = document.createElement("tr");
    row.innerHTML = `
      <td><input type="text" class="courseTitle" placeholder="e.g. MTH 101"></td>
      <td><input type="number" class="courseUnit" min="0" max="12" placeholder="e.g. 3"></td>
      <td><select class="courseGrade">${buildGradeOptions()}</select></td>
      <td><button type="button" class="gpa-remove-btn">Remove</button></td>
    `;
    row.querySelector(".gpa-remove-btn").addEventListener("click", () => row.remove());
    tableBody.appendChild(row);
  }

  function refreshAllGradeDropdowns() {
    document.querySelectorAll(".courseGrade").forEach(select => {
      const prevValue = select.value;
      select.innerHTML = buildGradeOptions();
      if ([...select.options].some(o => o.value === prevValue)) {
        select.value = prevValue;
      }
    });
  }

  document.getElementById("scale5").addEventListener("change", refreshAllGradeDropdowns);
  document.getElementById("scale4").addEventListener("change", refreshAllGradeDropdowns);

  addRowBtn.addEventListener("click", addRow);

  resetBtn.addEventListener("click", () => {
    tableBody.innerHTML = "";
    document.getElementById("totalUnits").textContent = "0";
    document.getElementById("totalPoints").textContent = "0.00";
    document.getElementById("semesterGPA").textContent = "0.00";
    document.getElementById("cumulativeCGPA").textContent = "—";
    document.getElementById("classificationResult").textContent = "Enter your courses above to see your result";
    document.getElementById("prevCGPA").value = "";
    document.getElementById("prevUnits").value = "";
    addRow(); addRow(); addRow();
  });

  function computeSemester() {
    const scale = currentScale();
    let totalUnits = 0;
    let totalPoints = 0;

    document.querySelectorAll("#gpaTableBody tr").forEach(row => {
      const unit = parseFloat(row.querySelector(".courseUnit").value) || 0;
      const grade = row.querySelector(".courseGrade").value;
      const point = scale[grade] !== undefined ? scale[grade] : 0;
      totalUnits += unit;
      totalPoints += unit * point;
    });

    const gpa = totalUnits > 0 ? (totalPoints / totalUnits) : 0;

    document.getElementById("totalUnits").textContent = totalUnits;
    document.getElementById("totalPoints").textContent = totalPoints.toFixed(2);
    document.getElementById("semesterGPA").textContent = gpa.toFixed(2);

    return { totalUnits, totalPoints, gpa };
  }

  function classify(cgpa) {
    const scale = currentScale();
    const isFivePoint = scale === gradePoints5;

    if (isFivePoint) {
      if (cgpa >= 4.50) return "First Class Honours";
      if (cgpa >= 3.50) return "Second Class Honours (Upper Division)";
      if (cgpa >= 2.40) return "Second Class Honours (Lower Division)";
      if (cgpa >= 1.50) return "Third Class Honours";
      if (cgpa >= 1.00) return "Pass";
      return "Below Pass Mark — check your school's regulations";
    } else {
      if (cgpa >= 3.50) return "First Class Honours";
      if (cgpa >= 3.00) return "Second Class Honours (Upper Division)";
      if (cgpa >= 2.00) return "Second Class Honours (Lower Division)";
      if (cgpa >= 1.00) return "Third Class Honours";
      return "Below Pass Mark — check your school's regulations";
    }
  }

  calcGpaBtn.addEventListener("click", () => {
    const { gpa } = computeSemester();
    document.getElementById("classificationResult").textContent = classify(gpa) + " (based on this semester's GPA)";
  });

  calcCgpaBtn.addEventListener("click", () => {
    const { totalUnits, totalPoints } = computeSemester();
    const prevCGPA = parseFloat(document.getElementById("prevCGPA").value) || 0;
    const prevUnits = parseFloat(document.getElementById("prevUnits").value) || 0;

    const prevPoints = prevCGPA * prevUnits;
    const combinedUnits = totalUnits + prevUnits;
    const combinedPoints = totalPoints + prevPoints;
    const newCGPA = combinedUnits > 0 ? (combinedPoints / combinedUnits) : 0;

    document.getElementById("cumulativeCGPA").textContent = newCGPA.toFixed(2);
    document.getElementById("classificationResult").textContent = classify(newCGPA) + " (based on cumulative CGPA)";
  });

  // seed with 3 empty rows on load
  addRow(); addRow(); addRow();
})();
</script>

