  <meta name="keywords" content="JAMB subject combination, course eligibility checker, JAMB requirements Nigeria, O'Level subject combination, subject combination for medicine, subject combination for law, subject combination for computer science, JAMB UTME brochure, WAEC requirements for university courses" />
  <meta name="author" content="UC Tech Hub">
  <meta name="robots" content="index, follow, max-image-preview:large">
  <link rel="canonical" href="https://mysearch-query.onrender.com/check/course-eligibility/app" />

  <!-- ===================== OPEN GRAPH (Facebook / LinkedIn / WhatsApp previews) ===================== -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="UC Tech Hub" />
  <meta property="og:title" content="JAMB Course Eligibility Checker | Check Your Subject Combination" />
  <meta property="og:description" content="Find the exact O'Level and JAMB subject combination required for any Nigerian university course, then check your own subjects instantly." />
  <meta property="og:url" content="https://mysearch-query.onrender.com/check/course-eligibility/app" />
  <meta property="og:image" content="https://mysearch-query.onrender.com/images/logo.jpg" />

  <!-- ===================== TWITTER CARD ===================== -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="JAMB Course Eligibility Checker | UC Tech Hub" />
  <meta name="twitter:description" content="Check the JAMB & O'Level subject combination required for your dream course in seconds." />
  <meta name="twitter:image" content="https://mysearch-query.onrender.com/images/logo.jpg" />

  <link rel="icon" href="/images/logo.jpg" type="image/jpeg">

  <!-- ===================== STRUCTURED DATA ===================== -->
  <!-- WebApplication schema: tells Google this is a free interactive tool, eligible for rich results -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "JAMB Course Eligibility Checker",
    "url": "https://mysearch-query.onrender.com/check/course-eligibility/app",
    "applicationCategory": "EducationApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "NGN" },
    "publisher": { "@type": "Organization", "name": "UC Tech Hub", "url": "https://mysearch-query.onrender.com" }
  }
  </script>

  <!-- FAQPage schema: mirrors the on-page FAQ below, so Google can show it as an expandable rich result -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What subjects do I need for Medicine and Surgery in JAMB?",
        "acceptedAnswer": { "@type": "Answer", "text": "English Language, Physics, Chemistry, and Biology are compulsory JAMB subjects for Medicine and Surgery at almost every Nigerian university, with no flexible alternatives." }
      },
      {
        "@type": "Question",
        "name": "Can I study Law without Literature in English?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most Nigerian universities expect Literature-in-English, Government, or CRK/IRK as part of your Law subject combination. Requirements differ slightly by school, so always confirm with your target university's admission page." }
      },
      {
        "@type": "Question",
        "name": "Do I need Physics for Computer Science?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes — English Language, Mathematics, and Physics are compulsory for Computer Science at most Nigerian universities, plus one additional science or related subject." }
      },
      {
        "@type": "Question",
        "name": "Where can I confirm the official JAMB subject combination for my course?",
        "acceptedAnswer": { "@type": "Answer", "text": "The definitive source is the current JAMB UTME brochure, cross-checked against your specific university's admission requirements page, since minor variations exist between institutions." }
      }
    ]
  }
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <a href="#main-content" class="visually-hidden-focusable">Skip to main content</a>

  <!-- ===================== HEADER ===================== -->
  <header class="nav-header" id="scrollHeader">
    <div class="logo"><img src="/images/logo.jpg" alt="UC Tech Hub logo"></div>
    <div class="menu-toggle" onclick="toggleMenu()" role="button" aria-label="Toggle navigation" tabindex="0">☰</div>
    <ul class="header-nav-links" id="navLinks">
      <li><a href="/">Home</a></li>
      <li><a href="/nigeria/list-of-institution/page">Universities</a></li>
      <li><a href="/calculate/cgpa/app">CGPA Calculator</a></li>
      <li><a href="/calculate/jamb-aggregate/app">Aggregate Calculator</a></li>
      <li class="contact-link"><a href="/contact-us/page">Contact Us</a></li>
    </ul>
  </header>
  <script>
    function toggleMenu() { document.getElementById('navLinks').classList.toggle('active'); }
  </script>

  <main id="main-content">

    <section class="hero">
      <h1>JAMB Course Eligibility & Subject Combination Checker</h1>
      <p>Find the O'Level and JAMB subject combination required for any Nigerian university course, then check your own subjects against it — free, instant, and updated for the current admission cycle.</p>
    </section>

    <div class="container">

      <div class="section-txt">
        <h2>⚠️ Before You Start</h2>
        <p>
          Subject combinations are broadly stable but can vary slightly between institutions for the
          same course (e.g. some schools accept Agricultural Science as a Biology substitute for
          Computer Science, others don't). This tool shows the <strong>most common combination</strong>
          published in the JAMB brochure — always confirm your specific school's requirement in the
          current JAMB UTME brochure or the school's admission page before finalizing your subjects.
        </p>
      </div>

      <!-- Course selector -->
      <div class="section-txt">
        <h2>1. Choose Your Intended Course</h2>
        <select id="courseSelect" class="jamb-input-grid-select" aria-label="Select your intended course"></select>
        <div id="courseRequirement" class="course-requirement-box" aria-live="polite"></div>
      </div>

      <!-- Subject checker -->
      <div class="section-txt">
        <h2>2. Check Your Subjects</h2>
        <p>English Language is compulsory for every course. Tick the other subjects you are offering or plan to offer:</p>
        <div class="subject-grid" id="subjectGrid"></div>
        <button type="button" class="cta-button" id="checkEligibilityBtn">Check My Eligibility</button>

        <div class="info-section">
          <div class="info-card" id="eligibilityCard">
            <h3>Result</h3>
            <p id="eligibilityResult" aria-live="polite">Select a course and your subjects above</p>
          </div>
        </div>
      </div>

      <!-- FAQ (matches the FAQPage schema above — real content Google can rank on long-tail searches) -->
      <div class="section-txt">
        <h2>Frequently Asked Questions</h2>
        <ul class="child-ul">
          <li><strong>What subjects do I need for Medicine and Surgery in JAMB?</strong> English Language, Physics, Chemistry, and Biology are compulsory at almost every Nigerian university, with no flexible alternatives.</li>
          <li><strong>Can I study Law without Literature in English?</strong> Most schools expect Literature-in-English, Government, or CRK/IRK as part of your combination — confirm with your target university since requirements vary slightly.</li>
          <li><strong>Do I need Physics for Computer Science?</strong> Yes — English, Mathematics, and Physics are compulsory at most schools, plus one additional science or related subject.</li>
          <li><strong>Where can I confirm the official subject combination for my course?</strong> The current JAMB UTME brochure, cross-checked against your specific university's admission page.</li>
        </ul>
      </div>

    </div>
  </main>

  <%- include('../includeFolder/jambHot_link6.ejs') %>
  <script src="/js/index.js"></script>
  <%- include('../includeFolder/_footer.ejs') %>

  <script>
  (function () {
    // Course requirement data comes from the server (renderFolder/courseEligibilityData.js),
    // passed in via res.render(..., { courseRequirements, masterSubjects }) in page.js.
    // To add/edit a course, edit that data file only — this script never changes.
    const courses = <%- courseRequirements %>;
    const masterSubjects = <%- masterSubjects %>;

    const courseSelect = document.getElementById("courseSelect");
    courses.forEach((c, i) => {
      const opt = document.createElement("option");
      opt.value = i;
      opt.textContent = c.name;
      courseSelect.appendChild(opt);
    });

    function showRequirement() {
      const course = courses[courseSelect.value];
      const box = document.getElementById("courseRequirement");
      box.innerHTML = `
        <h4>${course.name}</h4>
        <p><strong>O'Level:</strong> ${course.olevel}</p>
        <p><strong>JAMB Subjects:</strong> English Language${course.jambCore.filter(s => s !== "English Language").length ? ", " + course.jambCore.filter(s => s !== "English Language").join(", ") : ""}${course.jambFlexible.length ? " + " + course.flexibleCount + " of (" + course.jambFlexible.join(", ") + ")" : ""}</p>
        <p><em>${course.note}</em></p>
      `;
    }
    courseSelect.addEventListener("change", showRequirement);

    const subjectGrid = document.getElementById("subjectGrid");
    subjectGrid.innerHTML = `<label class="locked"><input type="checkbox" checked disabled> English Language (compulsory)</label>`;
    masterSubjects.forEach(subj => {
      const label = document.createElement("label");
      label.innerHTML = `<input type="checkbox" class="subjectCheckbox" value="${subj}"> ${subj}`;
      subjectGrid.appendChild(label);
    });

    document.getElementById("checkEligibilityBtn").addEventListener("click", () => {
      const course = courses[courseSelect.value];
      const selected = ["English Language"];
      document.querySelectorAll(".subjectCheckbox:checked").forEach(cb => selected.push(cb.value));

      const missingCore = course.jambCore.filter(s => !selected.includes(s));
      const flexibleMatches = course.jambFlexible.filter(s => selected.includes(s));
      const flexibleOk = course.flexibleCount === 0 || flexibleMatches.length >= course.flexibleCount;

      const resultEl = document.getElementById("eligibilityResult");
      if (missingCore.length === 0 && flexibleOk) {
        resultEl.className = "eligibility-pass";
        resultEl.textContent = `✅ Likely eligible for ${course.name} based on the subjects you selected. Always confirm with your specific target school.`;
      } else {
        let msg = `❌ Not yet eligible for ${course.name}. `;
        if (missingCore.length > 0) msg += `Missing compulsory subject(s): ${missingCore.join(", ")}. `;
        if (!flexibleOk) msg += `You need at least ${course.flexibleCount} of: ${course.jambFlexible.join(", ")}.`;
        resultEl.className = "eligibility-fail";
        resultEl.textContent = msg;
      }
    });

    showRequirement();
  })();
  </script>
</body>
</html>
